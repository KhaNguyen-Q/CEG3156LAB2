library ieee;
use ieee.std_logic_1164.all;

entity mux2to1_8bit is
    port (
        i_A, i_B : in  std_logic_vector(7 downto 0);
        i_S      : in  std_logic;
        o_Y      : out std_logic_vector(7 downto 0)
    );
end mux2to1_8bit;

architecture structural of mux2to1_8bit is
    component mux2to1_1bit
        port (i_A, i_B, i_S : in std_logic; o_Y : out std_logic);
    end component;
begin
    gen_mux: for i in 0 to 7 generate
        bit_mux: mux2to1_1bit port map (
            i_A => i_A(i),
            i_B => i_B(i),
            i_S => i_S,
            o_Y => o_Y(i)
        );
    end generate;
end structural;