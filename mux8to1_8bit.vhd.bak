LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY mux8to1_8bit IS
    PORT (
        i_sel : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
        i_R0, i_R1, i_R2, i_R3, i_R4, i_R5, i_R6, i_R7 : IN STD_LOGIC_VECTOR(7 DOWNTO 0);
        o_Y   : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
    );
END mux8to1_8bit;

ARCHITECTURE structural OF mux8to1_8bit IS
    -- Intermediate 8-bit buses between the layers of the tree
    SIGNAL s_L1_0, s_L1_1, s_L1_2, s_L1_3 : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL s_L2_0, s_L2_1 : STD_LOGIC_VECTOR(7 DOWNTO 0);

    COMPONENT mux2to1_8bit
        PORT (
            i_A, i_B : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            i_S      : IN  STD_LOGIC;
            o_Y      : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
        );
    END COMPONENT;

BEGIN
    -- LAYER 1: Select between 4 pairs using Bit 0 of the address
    MUX1_0: mux2to1_8bit PORT MAP (i_R0, i_R1, i_sel(0), s_L1_0);
    MUX1_1: mux2to1_8bit PORT MAP (i_R2, i_R3, i_sel(0), s_L1_1);
    MUX1_2: mux2to1_8bit PORT MAP (i_R4, i_R5, i_sel(0), s_L1_2);
    MUX1_3: mux2to1_8bit PORT MAP (i_R6, i_R7, i_sel(0), s_L1_3);

    -- LAYER 2: Select between the winners of Layer 1 using Bit 1
    MUX2_0: mux2to1_8bit PORT MAP (s_L1_0, s_L1_1, i_sel(1), s_L2_0);
    MUX2_1: mux2to1_8bit PORT MAP (s_L1_2, s_L1_3, i_sel(1), s_L2_1);

    -- LAYER 3: Final choice between the top 2 using Bit 2
    MUX3_Final: mux2to1_8bit PORT MAP (s_L2_0, s_L2_1, i_sel(2), o_Y);

END structural;